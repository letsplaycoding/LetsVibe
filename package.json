{
  "name": "letsvibe",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@9.15.4",
  "type": "module",
  "scripts": {
    "build": "corepack pnpm --filter @letsvibe/cli build",
    "web:dev": "corepack pnpm --filter @letsvibe/web dev",
    "web:build": "corepack pnpm --filter @letsvibe/web build",
    "dev": "npm run dev --workspace=@letsvibe/web"
  },
"workspaces": [
    "apps/*",
    "packages/*"
  ],
  "devDependencies": {
    "@types/node": "^20.17.10",
    "typescript": "^5.7.2"
  }
}
